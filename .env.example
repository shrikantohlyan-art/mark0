# Jarvis AI System - Environment Configuration
# Phase 1.3: Smart API Rotator Configuration

# ===========================
# 🔑 GEMINI API KEYS (REQUIRED)
# ===========================
# Add your Gemini API keys here with numbers
# Get keys from: https://aistudio.google.com/app/apikeys
# 
# Phase 1.3 Feature: These numbered keys will be automatically rotated
# on rate-limit (429) errors, allowing unlimited queries across multiple keys
#

GEMINI_API_KEY_1=your-first-gemini-api-key-here
GEMINI_API_KEY_2=your-second-gemini-api-key-here
GEMINI_API_KEY_3=your-third-gemini-api-key-here
GEMINI_API_KEY_4=your-fourth-gemini-api-key-here

# Fallback: Single key (if numbered keys not used)
# GEMINI_API_KEY=your-backup-gemini-api-key-here

# ===========================
# 🗂️ PROJECT PATHS
# ===========================

PROJECT_ROOT=./
BASE_DIR=./
LOGS_DIR=./logs
DATA_DIR=./data

# ===========================
# 🌐 SERVER CONFIGURATION
# ===========================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Vite frontend port used by the current Jarvis web UI
JARVIS_FRONTEND_PORT=5173

# ===========================
# 🧠 JARVIS CONFIGURATION
# ===========================

# Model selection
MODEL=gemini-1.5-flash

# System instruction for Jarvis
SYSTEM_INSTRUCTION=You are Jarvis, a high-level PC automation commander. Execute tasks precisely using the provided tools. Always confirm dangerous operations.

# Preferred language for voice and response styling
JARVIS_LANGUAGE=english
JARVIS_DEFAULT_TTS_VOICE=en-GB-RyanNeural
JARVIS_HINDI_TTS_VOICE=hi-IN-SwaraNeural
JARVIS_HINGLISH_TTS_VOICE=hi-IN-SwaraNeural

# User profile defaults for personalisation and local context
USER_NAME=Sir
USER_CITY=Ludhiana

# Autonomy level: supervised, authorized, or full
AUTONOMY_LEVEL=supervised

# Maximum steps for agent execution
MAX_AGENT_STEPS=4

# ===========================
# 📊 LOGGING CONFIGURATION
# ===========================

LOG_FILE=logs/jarvis_backend.log
LOG_LEVEL=INFO

# ===========================
# 👻 GHOST COLLECTOR (Phase 2)
# ===========================

# Training data path for pattern collection
TRAINING_DATA_PATH=Brain_Logs/training_data.jsonl

# Enable ghost collection (silent data capture)
GHOST_COLLECTION_ENABLED=true

# Prune patterns older than (days)
PRUNE_OLD_PATTERNS=30

# ===========================
# 📚 DATABASE CONFIGURATION
# ===========================

# Optional: For future database integration
DATABASE_URL=sqlite:///./jarvis.db

# ===========================
# 🌍 WEB RESEARCH INTEGRATIONS
# ===========================

# Firecrawl API key (optional, free tier available at firecrawl.dev)
FIRECRAWL_API_KEY=your-firecrawl-key

# News API key (optional, free tier available at newsapi.org)
NEWSAPI_KEY=your-newsapi-key

# Spotify app credentials (optional, required for richer music control)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ===========================
# 📧 EMAIL (IMAP) — OPTIONAL
# ===========================
# Used by the `email_read` tool. If not set, email tools will be skipped gracefully.
# For Gmail: enable IMAP and use an App Password (not your normal password).

EMAIL_USER=your-email@example.com
EMAIL_PASS=your-imap-app-password
EMAIL_HOST=imap.gmail.com

# Optional (for sending email via `email_send`)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ===========================
# 🔐 SECURITY
# ===========================

# Session timeout (minutes)
SESSION_TIMEOUT=60

# Enable SSL (for production)
SSL_ENABLED=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ===========================
# ⚡ API RATE LIMITING
# ===========================

# Rate limit for API calls (requests per minute)
RATE_LIMIT_RPM=60

# Enable API key rotation on rate limit
ENABLE_KEY_ROTATION=true

# Max retries before giving up
MAX_RETRIES=3

# ===========================
# 🎨 UI/UX PREFERENCES
# ===========================

THEME=dark
LANGUAGE=en
TIMEZONE=UTC

# ===========================
# 🔧 BACKEND SERVER CONFIGURATION (NEW)
# ===========================

# Backend server host and port (for uvicorn)
JARVIS_BACKEND_HOST=0.0.0.0
JARVIS_BACKEND_PORT=8001

# ===========================
# 🎯 LOGGING CONFIGURATION (NEW)
# ===========================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JARVIS_LOGGING_LEVEL=INFO

# Log directory path
JARVIS_LOGGING_PATH=logs

# ===========================
# 📡 HTTP CLIENT CONFIGURATION (NEW)
# ===========================

# HTTP connection timeout (seconds)
JARVIS_API_TIMEOUT=30

# HTTP retry strategy
JARVIS_API_MAX_RETRIES=3

# HTTP connection pool size
JARVIS_HTTP_POOL_SIZE=10

# ===========================
# 🤖 MODEL CONFIGURATION (NEW)
# ===========================

# Default model to use
JARVIS_MODEL_DEFAULT=gemini-2.0-flash

# Ollama server address (for local model fallback)
OLLAMA_HOST=http://localhost:11434

# Default Ollama model
OLLAMA_DEFAULT_MODEL=llama3

# ===========================
# 🚨 FEATURE FLAGS (NEW)
# ===========================

# Enable rate limiting middleware
JARVIS_RATE_LIMIT_ENABLED=true

# Enable health check endpoint
JARVIS_HEALTH_CHECK_ENABLED=true

# Enable verbose debug logging
JARVIS_DEBUG_MODE=false

# Enable screen watcher for activity analysis
JARVIS_ENABLE_SCREEN_WATCHER=true

# Enable web search functionality
JARVIS_ENABLE_WEB_SEARCH=true

# Enable voice command processing
JARVIS_ENABLE_VOICE_COMMANDS=true


# ===========================
# 📱 OPTIONAL INTEGRATIONS
# ===========================

# WhatsApp Integration (optional)
WHATSAPP_ENABLED=false
WHATSAPP_API_KEY=

# Email Integration (optional)
EMAIL_ENABLED=false
# For reading emails (IMAP) — tool: email_read
# Gmail: generate an App Password (recommended) and set it as EMAIL_PASS.
EMAIL_USER=
EMAIL_PASS=
EMAIL_HOST=imap.gmail.com

# For sending emails (SMTP) — tool: email_send
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ===========================
# 🔧 DEVELOPMENT
# ===========================

# Debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# ===========================
# NOTES
# ===========================
# 1. Copy this file as .env in your project root
# 2. Replace placeholder values with your actual settings
# 3. NEVER commit .env to version control
# 4. API key rotation works with GEMINI_API_KEY_1, GEMINI_API_KEY_2, ... (any number)
# 5. On rate limit (429), Jarvis automatically rotates to the next key
# 6. Keys are tried in order before failure (with backoff)
# 7. Ghost Collector captures patterns automatically for learning
# 8. Daily reports saved to Brain_Logs/reports/
